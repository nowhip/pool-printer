# =============================================
# Pool-Printer – Umgebungsvariablen
# =============================================
# Kopiere diese Datei nach .env.local und passe die Werte an:
#   cp .env.example .env.local
# =============================================


# ----- Web-App & Middleware (Pflicht) --------

# [PFLICHT] Geheimer Schlüssel für JWT-Token-Verschlüsselung (NextAuth)
# Generieren mit: openssl rand -base64 32
NEXTAUTH_SECRET=

# [PFLICHT] API-Schlüssel für die Kommunikation zwischen Print Middleware und Web-App
# Muss in Web-App und Middleware identisch sein
API_KEY=

# [PFLICHT für Public-Launcher] Server-seitiges Secret zum Signieren der Public Launch Tokens
# Das Secret bleibt nur auf dem Server (nicht im Launcher-Skript).
PUBLIC_LAUNCH_SECRET=

# [OPTIONAL] Gültigkeit des Public-Launch-Tokens (und Cookie-Max-Age) in Sekunden
# Fallback: 120
#PUBLIC_LAUNCH_TTL_SECONDS=120

# [OPTIONAL] Gültigkeit des einmaligen Launch-Grants (URL für Browser-Aktivierung) in Sekunden
# Fallback: 30
#PUBLIC_LAUNCH_GRANT_TTL_SECONDS=30

# [OPTIONAL] Ziel-URL, auf die nach erfolgreichem Cookie-Setzen weitergeleitet wird
# Relativ oder absolut möglich. Fallback: /public
#PUBLIC_LAUNCH_BROWSER_URL=/public


# ----- Web-App (Optional) --------------------

# [OPTIONAL] Basis-URL der Web-App (auch von der Print Middleware als API-URL verwendet)
# Fallback: http://localhost:3000
#NEXTAUTH_URL=http://localhost:3000


# [OPTIONAL] Netzwerkzugriff einschränken (1 = nur Loopback + privates LAN, 0 = keine IP-Einschränkung)
# Gilt für /api/print-Routen.
# Fallback: 1
#LAN_ONLY=1

# ----- Print Middleware (Optional) ------------

# [OPTIONAL] Abfrage-Intervall in Millisekunden – wie oft der Print Spooler geprüft wird
# Fallback: 3000
#POLL_INTERVAL=3000

# [OPTIONAL] Name des virtuellen S/W-Druckers in Windows
# Fallback: PoolDrucker_SW
#PRINTER_BW=PoolDrucker_SW

# [OPTIONAL] Name des virtuellen Farbdruckers in Windows
# Fallback: PoolDrucker_Farbe
#PRINTER_COLOR=PoolDrucker_Farbe


# ----- Rechnungs-/Belegdaten (Optional) ------
# Diese Daten erscheinen auf heruntergeladenen Belegen (PDF).
# Alle Felder sind optional – ohne Angabe wird nur "Pool Printer" als Absender gezeigt.

# [OPTIONAL] Logo-Datei: Lege eine Datei "logo.svg" im Ordner public/ ab.
# Sie wird automatisch im Browser-Tab, in der Sidebar und auf PDF-Belegen angezeigt.
# Kein Env-Eintrag nötig – einfach public/logo.svg ablegen.

# [OPTIONAL] Firmen- / Organisationsname
#NEXT_PUBLIC_INVOICE_COMPANY_NAME=Meine Uni – Copy Center

# [OPTIONAL] Adresse (mehrzeilig mit | trennen)
#NEXT_PUBLIC_INVOICE_COMPANY_ADDRESS=Musterstraße 1 | 12345 Musterstadt

# [OPTIONAL] Telefonnummer
#NEXT_PUBLIC_INVOICE_COMPANY_PHONE=+49 123 456789

# [OPTIONAL] E-Mail-Adresse
#NEXT_PUBLIC_INVOICE_COMPANY_EMAIL=info@example.de

# [OPTIONAL] Steuernummer oder USt-IdNr.
#NEXT_PUBLIC_INVOICE_TAX_ID=DE123456789

# [OPTIONAL] Steuersatz in Prozent (z. B. 19). Wenn 0 oder nicht gesetzt, wird keine Steuer ausgewiesen.
# Fallback: 0
#NEXT_PUBLIC_INVOICE_TAX_RATE=19

# [OPTIONAL] Währung (ISO 4217 Code)
# Fallback: EUR
#NEXT_PUBLIC_INVOICE_CURRENCY=EUR
